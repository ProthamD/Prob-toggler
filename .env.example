# TinyFish Web Agent API
TINYFISH_API_KEY=sk-tinyfish-oS4d3nXx-Eco83zakoFA1_1Ogdp4LJds
TINYFISH_API_BASE=https://agent.tinyfish.ai/v1

# Server Configuration
PORT=3000
NODE_ENV=development
MOCK_MODE=false

# Database
DATABASE_URL=sqlite:./data/hackathon.db

# Redis (for job queue)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Scraping Configuration
HACKATHON_PLATFORMS=hackerearth,devpost,mlh
MONITOR_INTERVAL_MINUTES=30
MAX_CONCURRENT_AGENTS=3

# Anti-Detection Configuration
ANTI_DETECTION_ENABLED=true
BROWSER_PROFILE=stealth
PROXY_ENABLED=true
PROXY_COUNTRY_CODE=US

