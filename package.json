{
  "name": "hackathon-ai-agent",
  "version": "0.1.0",
  "description": "AI-powered hackathon opportunity automation platform with TinyFish Web Agent",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "server": "tsx watch src/api/server.ts",
    "agent": "tsx src/agents/orchestrator.ts",
    "scrape:hackathons": "tsx src/agents/hackathon-scraper.ts",
    "scrape:solutions": "tsx src/agents/solution-finder.ts",
    "monitor": "tsx src/agents/opportunity-monitor.ts"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pino": "^8.16.2",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.5.9",
    "tsx": "^3.14.0",
    "typescript": "^5.2.2"
  }
}
